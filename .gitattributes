# Normalize line endings: store text as LF in the repo, check out native.
# Keeps diffs clean and silences the CRLF warnings on Windows.
* text=auto eol=lf

# Binary assets — never touch their bytes.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.mp3 binary
*.wav binary
*.ogg binary
